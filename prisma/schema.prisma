generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model News {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  content   String
  summary   String?
  imageUrl  String?  
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Event {
  id          String   @id @default(cuid())
  title       String
  description String
  location    String?
  startDate   DateTime
  endDate     DateTime?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TeamMember {
  id        String   @id @default(cuid())
  name      String
  position  String  
  bio       String?
  photoUrl  String?
  order     Int      @default(0) 
  socials   String?  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}